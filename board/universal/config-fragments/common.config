# =============================================================================
# Common configuration applied to ALL targets
# =============================================================================

# --- Init system ---
BR2_INIT_BUSYBOX=y
BR2_ROOTFS_DEVICE_CREATION_STATIC=y
BR2_SYSTEM_DHCP="eth0"
BR2_TARGET_GENERIC_REMOUNT_ROOTFS_RW=y

# --- Hostname / login banner ---
BR2_TARGET_GENERIC_HOSTNAME="muNeuron"
BR2_TARGET_GENERIC_ISSUE="Welcome to µNeuron"
BR2_TARGET_GENERIC_OS_NAME="µNeuron"
BR2_TARGET_GENERIC_OS_VERSION="1.0"

# --- Root password ---
# BR2_PACKAGE_HOST_MKPASSWD lets Buildroot hash the plain-text password
# itself at build time using mkpasswd.  The SHA-512 options tell it which
# algorithm to use.  BR2_TARGET_ENABLE_ROOT_LOGIN must be set explicitly
# when using systemd (it is not implied by setting a password).
BR2_TARGET_ENABLE_ROOT_LOGIN=y
BR2_TARGET_GENERIC_PASSWD_SHA512=y
BR2_TARGET_GENERIC_PASSWD_METHOD="sha-512"
BR2_TARGET_GENERIC_ROOT_PASSWD="muNeuron"
BR2_PACKAGE_HOST_MKPASSWD=y

# --- Packages ---
BR2_PACKAGE_NEOFETCH=y
BR2_SYSTEM_BIN_SH_ZSH=y
BR2_SYSTEM_BIN_SH="zsh"
BR2_PACKAGE_DROPBEAR=y

# --- Serial TTY ---
BR2_TARGET_GENERIC_GETTY=y
BR2_TARGET_GENERIC_GETTY_PORT="ttyAMA0"
BR2_TARGET_GENERIC_GETTY_BAUDRATE_KEEP=y
BR2_TARGET_GENERIC_GETTY_BAUDRATE="0"
BR2_TARGET_GENERIC_GETTY_TERM="screen-256color"
BR2_TARGET_GENERIC_GETTY_OPTIONS=""

# --- Python 3 ---
BR2_PACKAGE_PYTHON3=y
BR2_PACKAGE_PYTHON3_PY_PYC=y                 # compile .py to .pyc

# --- Useful extras that pair well with systemd+python3 ---
BR2_PACKAGE_DBUS=y                            # provides libdbus + tools (dbus-send, etc.)
BR2_PACKAGE_UTIL_LINUX=y
BR2_PACKAGE_UTIL_LINUX_BINARIES=y

# --- Python script requirements ---
# Python packages
BR2_PACKAGE_PYTHON3=y
BR2_PACKAGE_PYTHON3_PY_PYC=y
BR2_PACKAGE_PYTHON_PSUTIL=y
BR2_PACKAGE_PYTHON_SMBUS2=y
BR2_PACKAGE_PYTHON_CBOR2=y
BR2_PACKAGE_PYTHON_PILLOW=y
BR2_PACKAGE_PYTHON_LUMA_CORE=y
BR2_PACKAGE_PYTHON_LUMA_OLED=y

# Pillow needs these native libs
BR2_PACKAGE_JPEG=y
BR2_PACKAGE_ZLIB=y
BR2_PACKAGE_LIBPNG=y
BR2_PACKAGE_FREETYPE=y

# I2C support (needed for the SSD1306 display)
BR2_PACKAGE_I2C_TOOLS=y
BR2_PACKAGE_LINUX_KERNEL_NEEDS_HOST_OPENSSL=y

# Rootfs size (Python + Pillow + luma packages need more than 120M)
BR2_TARGET_ROOTFS_EXT2_SIZE="256M"

# --- Post build ---
BR2_ROOTFS_POST_BUILD_SCRIPT="$(TOPDIR)/../board/universal/post-build.sh"

# --- Rootfs overlay ---
# Merges board/universal/rootfs-overlay/ into the target rootfs at build time.
# TOPDIR is the buildroot/ submodule directory, so ../ is the repo root.
BR2_ROOTFS_OVERLAY="$(TOPDIR)/../board/universal/rootfs-overlay"

# --- Permissions table ---
# Ensures init scripts have execute bit set in the rootfs image.
# Git and Docker do not reliably preserve execute bits on overlay files.
BR2_ROOTFS_DEVICE_TABLE="$(TOPDIR)/../board/universal/device_table.txt"

